pipeline {
    agent any

    stages {

        stage('Gitleaks Scan') {
            steps {
                dir('Task_16/gitleaks-jenkins-demo/gitleaks-demo') {
                    sh 'gitleaks dir .'
                }
            }
        }

        stage('Build') {
            steps {
                dir('Task_16/gitleaks-jenkins-demo/gitleaks-demo') {
                    sh 'mvn clean package'
                }
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}
